---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---
<BaseLayout title="Free Guide: 5 Ways to Add Motion to Your Photography Portfolio | Burst2GIF" description="Free guide for photographers: Learn 5 practical ways to add GIFs and video to your photo galleries. No video camera needed. Download the PDF." ogUrl="https://www.boost.photo/hvco-guide">

    <!-- Opt-in page — single purpose: capture email -->
    <div class="min-h-screen flex items-center justify-center py-12 px-4">
        <div class="max-w-2xl w-full">
            <!-- Header -->
            <div class="text-center mb-10">
                <a href="/" class="text-xl font-bold text-slate-900">
                    Burst<span class="text-indigo-600">2</span>GIF
                    <span class="text-sm font-normal text-slate-400 ml-1">by boost.photo</span>
                </a>
            </div>

            <div class="bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden">
                <div class="p-8 lg:p-12">
                    <!-- Badge -->
                    <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-white bg-indigo-600 rounded-full">
                        Free Guide (PDF)
                    </span>

                    <!-- Headline -->
                    <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-4">
                        5 Ways to Add Motion to Your Photography Portfolio
                        <span class="gradient-text">&mdash; Without a Video Camera</span>
                    </h1>

                    <!-- Subheadline -->
                    <p class="text-lg text-slate-600 mb-8">
                        Learn how photographers are making their client galleries stand out with animated burst photos. Practical techniques you can use on your next shoot.
                    </p>

                    <!-- Fascination bullets -->
                    <ul class="space-y-3 mb-8">
                        <li class="flex items-start gap-3 text-slate-700">
                            <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span>The <strong>5 wedding moments</strong> that work best as animated GIFs (and the 3 that don't)</span>
                        </li>
                        <li class="flex items-start gap-3 text-slate-700">
                            <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span>How to <strong>shoot burst sequences</strong> that actually look smooth as animations</span>
                        </li>
                        <li class="flex items-start gap-3 text-slate-700">
                            <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span>The <strong>camera settings</strong> that make or break your burst-to-GIF results</span>
                        </li>
                        <li class="flex items-start gap-3 text-slate-700">
                            <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span>Why <strong>Pic-Time, Pixieset and SmartSlides</strong> galleries look 10x better with motion</span>
                        </li>
                        <li class="flex items-start gap-3 text-slate-700">
                            <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span>The <strong>10-second workflow</strong> I use to create 15+ GIFs per wedding (it used to take 2 hours)</span>
                        </li>
                    </ul>

                    <!-- Email form placeholder -->
                    <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
                        <p class="text-sm font-semibold text-slate-700 mb-4">Enter your email and get the guide instantly:</p>
                        <!-- TODO: Replace with LemonSqueezy or email provider form -->
                        <form class="flex flex-col sm:flex-row gap-3">
                            <input type="email" placeholder="your@email.com" class="flex-1 px-4 py-3 border border-slate-300 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" required>
                            <button type="submit" class="px-6 py-3 text-base font-semibold text-white bg-indigo-600 rounded-lg hover:bg-indigo-500 transition flex-shrink-0">
                                Send Me the Guide
                            </button>
                        </form>
                        <p class="text-xs text-slate-400 mt-3">No spam. Unsubscribe anytime.</p>
                    </div>
                </div>
            </div>

            <!-- Trust -->
            <p class="text-center text-sm text-slate-400 mt-6">
                Written by Marek Topolar &middot; Wedding photographer &middot; 200+ weddings &middot; Creator of Burst2GIF
            </p>
        </div>
    </div>

</BaseLayout>
