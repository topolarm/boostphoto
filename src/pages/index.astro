---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---
<BaseLayout
  title="Burst2GIF — Create GIF & Video from Burst Photos in Lightroom | No Photoshop Needed"
  description="Lightroom Classic plugin that converts burst photo sequences into smooth MP4 videos or animated GIFs. No Photoshop needed. Preserves all your edits. macOS. $39 lifetime."
  ogUrl="https://boost.photo/"
  ogTitle="Burst2GIF — Create GIF & Video from Burst Photos in Lightroom"
  ogDescription="Lightroom Classic plugin that converts burst photos into MP4 videos or GIFs. No Photoshop needed. One click, 10 seconds."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Burst2GIF",
      "description": "Lightroom Classic plugin that converts burst photo sequences into smooth MP4 videos or animated GIFs. 3 clicks, 10 seconds. Preserves all Lightroom edits.",
      "applicationCategory": "MultimediaApplication",
      "applicationSubCategory": "Photography Plugin",
      "operatingSystem": "macOS",
      "softwareRequirements": "Adobe Lightroom Classic 10.0+",
      "screenshot": "https://boost.photo/assets/images/demo-poster.jpg",
      "featureList": "MP4 and GIF export, Live preview, Auto-detect FPS from EXIF, Up to 6K resolution, Smart capture time, Import back to Lightroom",
      "offers": [
        {"@type": "Offer", "price": "0", "priceCurrency": "USD", "name": "Free", "description": "10 exports, 1500px max resolution"},
        {"@type": "Offer", "price": "39", "priceCurrency": "USD", "name": "Standard", "description": "Unlimited exports, 6K resolution, lifetime license"}
      ],
      "url": "https://boost.photo",
      "author": {"@type": "Person", "name": "Marek Topolar", "url": "https://boost.photo/about", "jobTitle": "Wedding Photographer & Developer"},
      "publisher": {"@type": "Organization", "name": "boost.photo", "url": "https://boost.photo"}
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to Create a GIF or MP4 from Burst Photos in Lightroom",
      "description": "Convert burst photo sequences into smooth animations directly inside Lightroom Classic using Burst2GIF.",
      "totalTime": "PT10S",
      "step": [
        {"@type": "HowToStep", "name": "Select burst photos", "text": "Choose your burst photos in Lightroom's Library module. Any sequence works — 10 photos or 100."},
        {"@type": "HowToStep", "name": "Preview and adjust settings", "text": "See your animation playing before you export. Adjust FPS in real-time or let the plugin detect it automatically from EXIF data."},
        {"@type": "HowToStep", "name": "Export", "text": "Choose MP4 or GIF format. Export to any folder, or import back to Lightroom automatically with the correct capture time."}
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "Can I use any images in Lightroom with Burst2GIF?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Burst2GIF works with any images in your Lightroom catalog — burst sequences, time-lapses, stop-motion, or any creative photo sequence you want to animate."}},
        {"@type": "Question", "name": "What cameras are supported?", "acceptedAnswer": {"@type": "Answer", "text": "Any camera that shoots burst mode. Burst2GIF reads timing from EXIF metadata (SubSecTimeOriginal) when available. Without millisecond timestamps, you can manually set the FPS. Supports 5fps to 120fps."}},
        {"@type": "Question", "name": "Does Burst2GIF work on Windows?", "acceptedAnswer": {"@type": "Answer", "text": "Burst2GIF is currently macOS only. A Windows version is on the roadmap."}},
        {"@type": "Question", "name": "Which Lightroom versions are supported?", "acceptedAnswer": {"@type": "Answer", "text": "Lightroom Classic 10.0 and newer. Does not work with Lightroom CC (cloud) or Lightroom mobile."}},
        {"@type": "Question", "name": "What is the difference between MP4 and GIF?", "acceptedAnswer": {"@type": "Answer", "text": "MP4 offers excellent quality with small file sizes (H.264 codec), best for social media and galleries. GIF plays automatically everywhere without a play button but has larger files and is limited to 256 colors."}},
        {"@type": "Question", "name": "Is Burst2GIF a subscription?", "acceptedAnswer": {"@type": "Answer", "text": "No. It is a one-time payment of $39 for a lifetime license, including all future updates. There is also a free version with 10 exports."}}
      ]
    })} />
  </Fragment>

  <Nav />

  <!-- HERO -->
  <section class="py-12 lg:py-16 relative overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-indigo-100 rounded-full blur-3xl opacity-50 -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-amber-100 rounded-full blur-3xl opacity-50 translate-y-1/2 -translate-x-1/2"></div>

      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative">
          <div class="text-center">
              <!-- Label -->
              <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-white bg-indigo-600 rounded-full shadow-lg shadow-indigo-200">
                  Lightroom Classic Plugin
              </span>

              <!-- H1 -->
              <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 mb-6">
                  Burst to GIF in 3 Clicks.<br>
                  <span class="gradient-text">Right Inside Lightroom.</span>
              </h1>

              <!-- Description -->
              <p class="max-w-3xl mx-auto text-lg md:text-xl text-slate-600 leading-relaxed mb-10">
                  Burst2GIF converts burst photo sequences into smooth MP4 videos
                  or animated GIFs &mdash; directly from Lightroom, preserving every edit you've made.
              </p>

              <!-- CTA Buttons -->
              <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
                  <a href="#pricing" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-white bg-indigo-600 rounded-lg hover:bg-indigo-500 transition glow-indigo">
                      Download Free - 10 exports
                  </a>
                  <a href="https://burst2gif.lemonsqueezy.com/buy/single" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-slate-900 bg-amber-400 rounded-lg hover:bg-amber-300 transition glow-amber">
                      Buy Standard $39 <span class="text-sm line-through opacity-70">$59</span>
                  </a>
              </div>

              <!-- Sub-info -->
              <p class="text-sm text-slate-500">
                  macOS &middot; Lightroom Classic &middot; No subscription
              </p>
          </div>

          <!-- Demo Video -->
          <div class="mt-16 max-w-4xl mx-auto">
              <div class="relative aspect-video rounded-2xl border border-slate-300 overflow-hidden shadow-2xl" id="demo-video-container">
                  <video id="demo-video" class="w-full h-full object-cover" muted playsinline controlsList="nodownload" preload="metadata" poster="/assets/images/demo-poster.jpg">
                      <source src="/assets/videos/demo.mp4" type="video/mp4">
                  </video>
                  <!-- Play Overlay -->
                  <div id="demo-overlay" class="absolute inset-0 bg-black/75 flex items-center justify-center cursor-pointer group" onclick="playDemoVideo()">
                      <div class="text-center">
                          <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-white flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform">
                              <svg class="w-12 h-12 text-indigo-600 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                  <path d="M8 5v14l11-7z"/>
                              </svg>
                          </div>
                          <p class="text-white font-semibold text-lg">Play our Demo video</p>
                          <p class="text-white/80 text-lg mt-1">(26 seconds)</p>
                      </div>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- PROBLEM & SOLUTION -->
  <section class="py-20 lg:py-28 bg-slate-900 text-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <!-- Header -->
          <div class="text-center mb-16">
              <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-slate-900 bg-amber-400 rounded-full">
                  The Problem
              </span>
              <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
                  You already shot the perfect burst.<br>
                  Why should sharing it be so hard?
              </h2>
          </div>

          <!-- Pain Points - Horizontal Process Flow -->
          <div class="flex flex-col lg:flex-row items-stretch justify-center gap-4 mb-12">
              <!-- Pain 1 -->
              <div class="flex-1 p-5 bg-slate-800/50 rounded-xl border border-slate-700 text-center">
                  <div class="w-10 h-10 mx-auto mb-3 rounded-lg bg-red-500/20 flex items-center justify-center">
                      <span class="text-red-400 font-bold">1</span>
                  </div>
                  <h3 class="text-base font-semibold text-white">Export 30+ JPEGs to folder</h3>
              </div>

              <!-- Arrow -->
              <div class="hidden lg:flex items-center justify-center text-slate-600">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
              </div>

              <!-- Pain 2 -->
              <div class="flex-1 p-5 bg-slate-800/50 rounded-xl border border-slate-700 text-center">
                  <div class="w-10 h-10 mx-auto mb-3 rounded-lg bg-red-500/20 flex items-center justify-center">
                      <span class="text-red-400 font-bold">2</span>
                  </div>
                  <h3 class="text-base font-semibold text-white">Open separate video editor</h3>
              </div>

              <!-- Arrow -->
              <div class="hidden lg:flex items-center justify-center text-slate-600">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
              </div>

              <!-- Pain 3 -->
              <div class="flex-1 p-5 bg-slate-800/50 rounded-xl border border-slate-700 text-center">
                  <div class="w-10 h-10 mx-auto mb-3 rounded-lg bg-red-500/20 flex items-center justify-center">
                      <span class="text-red-400 font-bold">3</span>
                  </div>
                  <h3 class="text-base font-semibold text-white">10 min of timeline work</h3>
              </div>

              <!-- Arrow -->
              <div class="hidden lg:flex items-center justify-center text-slate-600">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
              </div>

              <!-- Pain 4 -->
              <div class="flex-1 p-5 bg-slate-800/50 rounded-xl border border-slate-700 text-center">
                  <div class="w-10 h-10 mx-auto mb-3 rounded-lg bg-red-500/20 flex items-center justify-center">
                      <span class="text-red-400 font-bold">4</span>
                  </div>
                  <h3 class="text-base font-semibold text-white">Export &amp; set correct capture time</h3>
              </div>
          </div>

          <!-- Arrow + Solution -->
          <div class="text-center">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-400 mb-8">
                  <svg class="w-6 h-6 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
              </div>

              <div class="max-w-2xl mx-auto p-8 bg-gradient-to-br from-indigo-600 to-indigo-700 rounded-2xl shadow-xl">
                  <div class="flex items-center justify-center gap-3 mb-4">
                      <div class="w-10 h-10 rounded-full bg-emerald-400 flex items-center justify-center">
                          <svg class="w-5 h-5 text-emerald-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                          </svg>
                      </div>
                      <h3 class="text-2xl md:text-3xl font-bold text-white">With Burst2GIF</h3>
                  </div>
                  <p class="text-lg text-indigo-100 mb-6">
                      Select photos in Lightroom &rarr; Click export &rarr; Done.
                  </p>
                  <div class="flex flex-wrap items-center justify-center gap-4 text-sm">
                      <span class="px-3 py-1.5 bg-white/20 text-white rounded-full">10 seconds</span>
                      <span class="px-3 py-1.5 bg-white/20 text-white rounded-full">No video editor</span>
                      <span class="px-3 py-1.5 bg-white/20 text-white rounded-full">Edits preserved</span>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="py-20 lg:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16">
              <!-- Label -->
              <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-white bg-indigo-600 rounded-full">
                  How It Works
              </span>

              <!-- H2 -->
              <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
                  Three clicks. Ten seconds. Done.
              </h2>
          </div>

          <!-- Steps -->
          <div class="space-y-16 lg:space-y-24">
              <!-- Step 1 -->
              <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
                  <div class="order-2 lg:order-1">
                      <div class="flex items-center gap-4 mb-4">
                          <span class="flex items-center justify-center w-12 h-12 rounded-full bg-indigo-600 text-white font-bold text-lg shadow-lg shadow-indigo-200">1</span>
                          <h3 class="text-xl md:text-2xl font-semibold text-slate-900">Select</h3>
                      </div>
                      <p class="text-lg text-slate-600 leading-relaxed">
                          Choose your burst photos in Lightroom's Library module.
                          Any sequence works &mdash; 10 photos or 100. As many as you want.
                      </p>
                  </div>
                  <div class="order-1 lg:order-2">
                      <video class="w-full rounded-xl border border-slate-300 shadow-xl" autoplay muted loop playsinline>
                          <source src="/assets/videos/1choose.mp4" type="video/mp4">
                      </video>
                  </div>
              </div>

              <!-- Step 2 -->
              <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
                  <div class="order-2">
                      <div class="flex items-center gap-4 mb-4">
                          <span class="flex items-center justify-center w-12 h-12 rounded-full bg-amber-400 text-slate-900 font-bold text-lg shadow-lg shadow-amber-200">2</span>
                          <h3 class="text-xl md:text-2xl font-semibold text-slate-900">Preview and settings</h3>
                      </div>
                      <p class="text-lg text-slate-600 leading-relaxed">
                          See your animation playing before you export.
                          Adjust FPS in real-time or let the plugin detect it automatically.
                      </p>
                  </div>
                  <div class="order-1">
                      <video class="w-full rounded-xl border border-slate-300 shadow-xl" autoplay muted loop playsinline>
                          <source src="/assets/videos/2preview.mp4" type="video/mp4">
                      </video>
                  </div>
              </div>

              <!-- Step 3 -->
              <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
                  <div class="order-2 lg:order-1">
                      <div class="flex items-center gap-4 mb-4">
                          <span class="flex items-center justify-center w-12 h-12 rounded-full bg-emerald-500 text-white font-bold text-lg shadow-lg shadow-emerald-200">3</span>
                          <h3 class="text-xl md:text-2xl font-semibold text-slate-900">Export</h3>
                      </div>
                      <p class="text-lg text-slate-600 leading-relaxed">
                          Choose MP4 or GIF. Export to any folder, or import back to Lightroom
                          automatically with the correct capture time.
                      </p>
                  </div>
                  <div class="order-1 lg:order-2">
                      <video class="w-full rounded-xl border border-slate-300 shadow-xl" autoplay muted loop playsinline>
                          <source src="/assets/videos/3export.mp4" type="video/mp4">
                      </video>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- FEATURES - BENTO GRID -->
  <section id="features" class="py-20 lg:py-28 bg-gradient-to-br from-indigo-50 via-white to-slate-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16">
              <!-- Label -->
              <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-white bg-indigo-600 rounded-full">
                  Features
              </span>

              <!-- H2 -->
              <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
                  Everything you need. Nothing you don't.
              </h2>
          </div>

          <!-- Bento Grid -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">

              <!-- Feature 1 - MP4 & GIF -->
              <div class="col-span-2 p-6 bg-gradient-to-br from-indigo-600 to-indigo-700 rounded-2xl shadow-lg card-hover">
                  <div class="flex items-start gap-4">
                      <div class="text-4xl">&#127916;</div>
                      <div>
                          <h3 class="text-xl font-bold text-white mb-2">MP4 & GIF Export</h3>
                          <p class="text-indigo-100">
                              H.264 codec for universal compatibility. Up to 6K resolution.
                          </p>
                          <div class="mt-4 flex gap-2">
                              <span class="px-2 py-0.5 bg-white/20 text-white text-xs rounded-full">H.264</span>
                              <span class="px-2 py-0.5 bg-white/20 text-white text-xs rounded-full">6K</span>
                          </div>
                      </div>
                  </div>
              </div>

              <!-- Feature 2 - Live Preview -->
              <div class="col-span-1 p-6 bg-white rounded-2xl border border-slate-200 shadow-sm card-hover">
                  <div class="text-3xl mb-4">&#128065;</div>
                  <h3 class="text-lg font-semibold text-slate-900 mb-2">Live Preview</h3>
                  <p class="text-slate-600 text-sm">
                      See your animation before export. Adjust FPS in real-time.
                  </p>
              </div>

              <!-- Feature 3 - Auto FPS -->
              <div class="col-span-1 p-6 bg-amber-400 rounded-2xl shadow-sm card-hover">
                  <div class="text-3xl mb-4">&#9889;</div>
                  <h3 class="text-lg font-semibold text-slate-900 mb-2">Auto-Detect FPS</h3>
                  <p class="text-slate-700 text-sm">
                      Reads SubSecTime from EXIF. Perfect timing, automatically.
                  </p>
              </div>

              <!-- Feature 4 - macOS native -->
              <div class="col-span-2 p-6 bg-indigo-100 rounded-2xl border border-indigo-200 card-hover">
                  <div class="flex items-start gap-4">
                      <div class="text-3xl">&#63743;</div>
                      <div>
                          <h3 class="text-lg font-semibold text-slate-900 mb-2">Native on macOS</h3>
                          <p class="text-slate-600 text-sm">
                              Plug &amp; play. No extra software needed. Just install and go.
                          </p>
                      </div>
                  </div>
              </div>

              <!-- Feature 5 - Correct Capture Time -->
              <div class="col-span-2 p-6 bg-white rounded-2xl border border-slate-200 shadow-sm card-hover">
                  <div class="flex items-start gap-4">
                      <div class="text-3xl">&#128197;</div>
                      <div>
                          <h3 class="text-lg font-semibold text-slate-900 mb-2">Smart Capture Time</h3>
                          <p class="text-slate-600 text-sm">
                              Auto-sets correct timestamp based on your burst sequence. MP4 export only.
                          </p>
                      </div>
                  </div>
              </div>

              <!-- Bonus - Wide stats bar -->
              <div class="col-span-2 lg:col-span-4 p-8 bg-gradient-to-r from-indigo-600 via-indigo-500 to-amber-400 rounded-2xl shadow-lg">
                  <p class="text-center text-xl md:text-2xl font-semibold text-white">
                      Save up to 90% of your time creating MP4/GIF animations from your photos
                  </p>
              </div>
          </div>
      </div>
  </section>


  <!-- PERFECT FOR -->
  <section class="py-20 lg:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16">
              <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-white bg-indigo-600 rounded-full">
                  Use Cases
              </span>
              <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
                  Perfect for
              </h2>
          </div>

          <!-- Use Cases Grid -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
              <!-- Wedding -->
              <div class="flex flex-col">
                  <h3 class="text-lg font-semibold text-slate-900 text-center mb-3">Weddings &amp; Couples</h3>
                  <div class="p-5 bg-slate-200 rounded-2xl">
                      <video class="w-full aspect-square object-cover rounded-lg lazy-video" muted loop playsinline preload="none" data-src="/assets/videos/wedding.mp4">
                      </video>
                  </div>
              </div>

              <!-- Family -->
              <div class="flex flex-col">
                  <h3 class="text-lg font-semibold text-slate-900 text-center mb-3">Family, pets, kids</h3>
                  <div class="p-5 bg-slate-200 rounded-2xl">
                      <video class="w-full aspect-square object-cover rounded-lg lazy-video" muted loop playsinline preload="none" data-src="/assets/videos/family-pets.mp4">
                      </video>
                  </div>
              </div>

              <!-- Wildlife -->
              <div class="flex flex-col">
                  <h3 class="text-lg font-semibold text-slate-900 text-center mb-3">Wildlife</h3>
                  <div class="p-5 bg-slate-200 rounded-2xl">
                      <video class="w-full aspect-square object-cover rounded-lg lazy-video" muted loop playsinline preload="none" data-src="/assets/videos/wildlife.mp4">
                      </video>
                  </div>
              </div>

              <!-- Sports -->
              <div class="flex flex-col">
                  <h3 class="text-lg font-semibold text-slate-900 text-center mb-3">Sports</h3>
                  <div class="p-5 bg-slate-200 rounded-2xl">
                      <video class="w-full aspect-square object-cover rounded-lg lazy-video" muted loop playsinline preload="none" data-src="/assets/videos/sport.mp4">
                      </video>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-20 lg:py-28 bg-slate-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16">
              <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-white bg-indigo-600 rounded-full">
                  Testimonials
              </span>
              <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">
                  Loved by photographers worldwide
              </h2>
          </div>

          <!-- Testimonials Grid -->
          <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
              <!-- Testimonial 1 - Family -->
