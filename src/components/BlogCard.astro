---
interface Props {
  title: string;
  description: string;
  date: Date;
  image: string;
  imageAlt: string;
  slug: string;
  tags: string[];
}

const { title, description, date, image, imageAlt, slug, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<a href={`/blog/${slug}`} class="group block border border-slate-200 rounded-2xl shadow-sm hover:shadow-lg transition overflow-hidden">
  <img
    src={image}
    alt={imageAlt}
    class="aspect-video w-full object-cover rounded-t-2xl"
    loading="lazy"
  />
  <div class="p-6">
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.slice(0, 3).map(tag => (
        <span class="text-xs font-medium bg-indigo-50 text-indigo-600 rounded-full px-2 py-0.5">{tag}</span>
      ))}
    </div>
    <h3 class="text-lg font-semibold text-slate-900 group-hover:text-indigo-600 transition mb-1">{title}</h3>
    <p class="text-sm text-slate-500 mb-2">{formattedDate}</p>
    <p class="text-slate-600 line-clamp-2">{description}</p>
  </div>
</a>
