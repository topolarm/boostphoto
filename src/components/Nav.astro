---
interface Props {
  activeLink?: string;
}
const { activeLink } = Astro.props;
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <a href="/" class="text-xl font-bold text-slate-900">
                Burst<span class="text-indigo-600">2</span>GIF
                <span class="text-sm font-normal text-slate-400 ml-1">by boost.photo</span>
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center space-x-8">
                <a href="/#how-it-works" class="text-slate-600 hover:text-slate-900 transition">How it works</a>
                <a href="/#features" class="text-slate-600 hover:text-slate-900 transition">Features</a>
                <a href="/#pricing" class="text-slate-600 hover:text-slate-900 transition">Pricing</a>
                <a href="/#faq" class="text-slate-600 hover:text-slate-900 transition">FAQ</a>
                <a href="/blog" class:list={["text-slate-600 hover:text-slate-900 transition", { "text-slate-900 font-medium": activeLink === 'blog' }]}>Blog</a>
                <a href="/about" class:list={["text-slate-600 hover:text-slate-900 transition", { "text-slate-900 font-medium": activeLink === 'about' }]}>About</a>
                <a href="https://boostphoto.lemonsqueezy.com/checkout/buy/9cd642ca-5f6e-42f8-b22b-eff44f377977" class="px-4 py-2 text-sm font-semibold text-white bg-indigo-600 rounded-lg hover:bg-indigo-500 transition glow-indigo">
                    Download Free
                </a>
            </div>

            <!-- Mobile menu button -->
            <button data-menu-toggle type="button" class="md:hidden inline-flex items-center p-2 text-slate-600 hover:text-slate-900 focus:outline-none" aria-controls="mobile-menu" aria-expanded="false">
                <span class="sr-only">Open main menu</span>
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>

        <!-- Mobile menu -->
        <div class="hidden md:hidden" id="mobile-menu">
            <div class="px-2 pt-2 pb-4 space-y-1 border-t border-slate-200">
                <a href="/#how-it-works" class="block px-3 py-2 text-slate-600 hover:text-slate-900 transition">How it works</a>
                <a href="/#features" class="block px-3 py-2 text-slate-600 hover:text-slate-900 transition">Features</a>
                <a href="/#pricing" class="block px-3 py-2 text-slate-600 hover:text-slate-900 transition">Pricing</a>
                <a href="/#faq" class="block px-3 py-2 text-slate-600 hover:text-slate-900 transition">FAQ</a>
                <a href="/blog" class="block px-3 py-2 text-slate-600 hover:text-slate-900 transition">Blog</a>
                <a href="/about" class="block px-3 py-2 text-slate-600 hover:text-slate-900 transition">About</a>
                <a href="https://boostphoto.lemonsqueezy.com/checkout/buy/9cd642ca-5f6e-42f8-b22b-eff44f377977" class="block px-3 py-2 mt-2 text-center text-sm font-semibold text-white bg-indigo-600 rounded-lg hover:bg-indigo-500 transition">
                    Download Free
                </a>
            </div>
        </div>
    </div>
</nav>
<div class="h-16"></div>

<script is:inline>
    document.querySelector('[data-menu-toggle]')?.addEventListener('click', function() {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
</script>
