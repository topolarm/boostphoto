---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;

// Show only H2 headings for clean overview
const toc = headings.filter(h => h.depth === 2);
---

{toc.length > 2 && (
  <nav class="not-prose mb-10 p-6 bg-slate-50 border border-slate-200 rounded-xl">
    <p class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-3">In this article</p>
    <ol class="space-y-1.5 text-sm">
      {toc.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class="text-slate-500 hover:text-indigo-600 transition leading-snug block"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
