---
interface Props {
  variant?: 'full' | 'inline';
}
const { variant = 'full' } = Astro.props;
---

{variant === 'full' ? (
  <div class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-indigo-700 to-indigo-800 rounded-2xl p-8 md:p-10 mt-12 text-center">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-500/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-amber-400/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

    <div class="relative">
      <span class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-indigo-200 bg-indigo-500/30 rounded-full">Try it free</span>
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Ready to skip the Photoshop hassle?</h2>
      <p class="text-indigo-100 mb-8 max-w-lg mx-auto">3 clicks. 10 seconds. No Photoshop needed. Download Burst2GIF and create your first GIF in under 2 minutes.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/#pricing"
          class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-indigo-700 bg-white rounded-lg hover:bg-indigo-50 transition shadow-lg shadow-indigo-900/20"
        >
          Download Free &mdash; 10 exports
        </a>
        <a
          href="https://boostphoto.lemonsqueezy.com/checkout/buy/6ba26fba-8555-4797-9b9b-5a03f475b4a5"
          class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-slate-900 bg-amber-400 rounded-lg hover:bg-amber-300 transition shadow-lg shadow-amber-400/20"
        >
          Buy Standard $39 <span class="text-sm font-normal line-through opacity-70 ml-2">$59</span>
        </a>
      </div>
      <p class="text-indigo-300/70 text-xs mt-5">macOS &middot; Lightroom Classic &middot; No subscription &middot; 14-day money-back guarantee</p>
    </div>
  </div>
) : (
  <div class="relative overflow-hidden bg-gradient-to-r from-indigo-600 to-indigo-700 rounded-xl p-6 my-10 not-prose">
    <div class="absolute top-0 right-0 w-32 h-32 bg-amber-400/10 rounded-full blur-2xl"></div>
    <div class="relative flex flex-col sm:flex-row items-center gap-4">
      <div class="flex-1 text-center sm:text-left">
        <p class="text-white font-semibold text-lg">Turn your burst photos into GIFs in 10 seconds.</p>
        <p class="text-indigo-200 text-sm mt-1">Free version &mdash; 10 exports, no credit card needed.</p>
      </div>
      <a
        href="/#pricing"
        class="flex-shrink-0 inline-flex items-center px-6 py-2.5 text-sm font-semibold text-indigo-700 bg-white rounded-lg hover:bg-indigo-50 transition shadow-lg shadow-indigo-900/20"
      >
        Try Burst2GIF Free
      </a>
    </div>
  </div>
)}
