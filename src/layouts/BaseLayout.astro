---
interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  noindex?: boolean;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = 'https://boost.photo/og-image.png',
  ogUrl,
  noindex = false,
  canonicalUrl,
} = Astro.props;

const canonical = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content="Marek Topolar">
    {noindex && <meta name="robots" content="noindex">}
    <link rel="canonical" href={canonical}>

    <!-- Organization schema (site-wide) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "boost.photo",
      "url": "https://boost.photo",
      "logo": "https://boost.photo/favicon.svg",
      "email": "hello@boost.photo",
      "founder": { "@type": "Person", "name": "Marek Topolar" }
    })} />

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={ogUrl || canonical}>
    <meta property="og:title" content={ogTitle || title}>
    <meta property="og:description" content={ogDescription || description}>
    <meta property="og:image" content={ogImage}>

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content={ogTitle || title}>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Inter font (self-hosted, no external requests) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
    <style>
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap; src: url('/fonts/inter-latin.woff2') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 600; font-display: swap; src: url('/fonts/inter-latin.woff2') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap; src: url('/fonts/inter-latin.woff2') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap; src: url('/fonts/inter-latin-ext.woff2') format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
    </style>

    <!-- DNS prefetch for external services -->
    <link rel="dns-prefetch" href="//boostphoto.lemonsqueezy.com">
    <link rel="dns-prefetch" href="//googletagmanager.com">

    <slot name="head" />
</head>
<body class="bg-white text-slate-900 font-sans antialiased">
    <main>
        <slot />
    </main>

    <!-- Cookie Banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-slate-900 border-t border-slate-700 p-4 transform translate-y-full transition-transform duration-300">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm text-slate-300 text-center sm:text-left">
                We use cookies for analytics (Google Analytics) and fonts (Google Fonts).
                <a href="/privacy" class="text-indigo-400 hover:text-indigo-300 transition underline">Privacy Policy</a>
            </p>
            <div class="flex gap-2">
                <button onclick="declineCookies()" class="flex-shrink-0 px-4 py-2 text-sm font-medium text-slate-300 bg-slate-700 rounded-lg hover:bg-slate-600 transition">
                    Decline
                </button>
                <button onclick="acceptCookies()" class="flex-shrink-0 px-4 py-2 text-sm font-medium text-slate-900 bg-white rounded-lg hover:bg-slate-100 transition">
                    Accept
                </button>
            </div>
        </div>
    </div>
    <script is:inline>
        function acceptCookies() {
            localStorage.setItem('cookieConsent', 'accepted');
            document.getElementById('cookie-banner').classList.add('translate-y-full');
            loadGoogleAnalytics();
        }
        function declineCookies() {
            localStorage.setItem('cookieConsent', 'declined');
            document.getElementById('cookie-banner').classList.add('translate-y-full');
        }
        function loadGoogleAnalytics() {
            var gaId = 'GA_MEASUREMENT_ID';
            if (gaId === 'GA_MEASUREMENT_ID') return;
            var script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
            document.head.appendChild(script);
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', gaId, { anonymize_ip: true });
        }
        document.addEventListener('DOMContentLoaded', function() {
            var consent = localStorage.getItem('cookieConsent');
            if (!consent) {
                setTimeout(function() {
                    document.getElementById('cookie-banner').classList.remove('translate-y-full');
                }, 1000);
            } else if (consent === 'accepted') {
                loadGoogleAnalytics();
            }
        });
    </script>
</body>
</html>
